{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "landing",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "landing", "--listen", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=web"],
      "port": 3001
    },
    {
      "name": "mcp",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=mcp"],
      "port": 3002
    }
  ]
}
